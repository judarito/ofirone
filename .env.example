VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPER_ADMIN_EMAILS=admin@empresa.com,seguridad@empresa.com
VITE_CHAT_ORDER_EDGE_FUNCTION=chat-order-parser
VITE_DEEPSEEK_OCR_EDGE_FUNCTION=deepseek-ocr-proxy
VITE_DEEPSEEK_TEXT_EDGE_FUNCTION=deepseek-proxy
VITE_DEEPSEEK_TEXT_MODEL=deepseek-chat
VITE_OPS_RAG_EDGE_FUNCTION=ops-rag-agent
VITE_PRODUCT_PHOTO_PARSER_EDGE_FUNCTION=product-photo-parser
VITE_PRODUCT_PHOTO_ANALYZER_EDGE_FUNCTION=product-photo-analyzer
VITE_MP_CREATE_PREFERENCE_EDGE_FUNCTION=mercadopago-create-preference-v2
VITE_TENANT_MP_CONFIG_EDGE_FUNCTION=tenant-mercadopago-config
VITE_NOTIFICATION_DISPATCHER_EDGE_FUNCTION=notification-dispatcher
VITE_SUBSCRIPTION_CREATE_PREFERENCE_EDGE_FUNCTION=subscription-create-preference
VITE_SUBSCRIPTION_PROVISION_EDGE_FUNCTION=subscription-provision-signup

# AI key no va en frontend. Configura DEEPSEEK_API_KEY como secreto de Supabase Edge Functions.
# RESEND_API_KEY, RESEND_FROM_EMAIL y RESEND_FROM_NAME tampoco van en frontend:
# configuralos como secretos de Supabase Edge Functions.
# OFIRONE_MP_ACCESS_TOKEN tambien es secreto de Supabase Edge Functions para cobrar suscripciones SaaS.
# OFIRONE_PUBLIC_APP_URL=https://ofirone.com tambien es secreto de Edge Functions para links de acceso SaaS.
# OFIRONE_AUTH_RECOVERY_URL=https://ofirone.com/login opcional si quieres una URL exacta para crear contrasena.
